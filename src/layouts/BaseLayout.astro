---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  titre: string;
  description?: string;
}
const { titre, description = "Association Culture et Patrimoine en Boisset — culture, patrimoine, histoire et environnement." } = Astro.props;
const titreComplet = `${titre} — Culture et Patrimoine en Boisset`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titreComplet}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Polices : Spectral (titres) + Inter (texte). Hébergées par Google Fonts.
         Note souveraineté : pour un site 100 % européen sans dépendance à Google,
         on pourra plus tard servir ces polices en local (paquet @fontsource-*). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Spectral:wght@500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#contenu" class="skip-link">Aller au contenu</a>
    <Header />
    <main id="contenu">
      <slot />
    </main>
    <Footer />
  </body>
</html>
