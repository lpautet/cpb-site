---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout titre="Informations pratiques & contact">
  <section class="section">
    <div class="container stack" style="max-width:820px;">
      <p class="eyebrow">Nous joindre</p>
      <h1>Informations pratiques</h1>
      <hr class="river-rule" aria-hidden="true" />

      <h2>Contact</h2>
      <p>Adresse e-mail : <a href="mailto:contact@exemple.fr">contact@exemple.fr</a>
        <!-- TODO : remplacer par l'adresse définitive une fois le domaine choisi
             et la messagerie Microsoft 365 configurée. --></p>

      <h2>Écrivez-nous</h2>
      <!--
        FORMULAIRE DE CONTACT — à activer.
        Un site statique n'a pas de serveur : l'envoi passe par un service tiers
        ou une petite fonction. Le champ « website » ci-dessous est un piège à
        robots (honeypot) : laissé vide par les humains, rempli par les spams.
        Voir README, section « Formulaire de contact ».
      -->
      <form class="form" method="POST" action="#" hidden>
        <p class="form__row">
          <label for="nom">Nom</label>
          <input id="nom" name="nom" type="text" required autocomplete="name" />
        </p>
        <p class="form__row">
          <label for="email">Adresse e-mail</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </p>
        <p class="form__row">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </p>
        <p hidden aria-hidden="true">
          <label>Ne pas remplir<input name="website" tabindex="-1" autocomplete="off" /></label>
        </p>
        <p><button class="btn btn--primary" type="submit">Envoyer</button></p>
      </form>
      <p><em>Le formulaire de contact sera activé prochainement. En attendant,
        écrivez-nous directement par e-mail.</em></p>
    </div>
  </section>
</BaseLayout>

<style>
  .form__row { display: grid; gap: 0.35rem; margin-bottom: 1rem; }
  .form label { font-weight: 600; }
  .form input, .form textarea { font: inherit; padding: 0.6rem 0.7rem; border: 1px solid var(--stone-line); border-radius: var(--radius); background: #fff; }
  .form input:focus, .form textarea:focus { outline: 3px solid var(--river); outline-offset: 1px; }
</style>
