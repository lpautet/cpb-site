---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout titre="Adhésion & soutien">
  <section class="section">
    <div class="container stack" style="max-width:820px;">
      <p class="eyebrow">Nous soutenir</p>
      <h1>Adhérer & soutenir l'association</h1>
      <hr class="river-rule" aria-hidden="true" />
      <p class="lede">En adhérant, vous soutenez nos actions et participez à la vie de l'association.</p>

      <h2>Comment adhérer</h2>
      <p><!-- TODO : montant de la cotisation, modalités. Option simple et sans
           contrainte RGPD : proposer le bulletin d'adhésion en PDF à télécharger,
           à renvoyer accompagné du règlement. -->À compléter.</p>
      <p><a class="btn btn--primary" href="/infos-pratiques">Nous contacter</a></p>
    </div>
  </section>
</BaseLayout>
